# ──────────────────────────────────────────────
# Edge Function 시크릿 (supabase secrets set 으로만 관리)
# 이 파일에 실제 값을 넣지 말 것
# ──────────────────────────────────────────────

# Supabase (자동 주입 — 별도 설정 불필요)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# 토스페이먼츠 결제
TOSS_SECRET_KEY=

# ImageKit 이미지 업로드
IMAGEKIT_PRIVATE_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Cloud (AI 생성)
GOOGLE_CLOUD_PRIVATE_KEY=
GOOGLE_CLOUD_CLIENT_EMAIL=

# CORS 허용 출처 (쉼표 구분 exact match, 와일드카드 미지원, 미설정 시 개발 환경에서 전체 허용)
ALLOWED_ORIGINS=https://example.com,https://sub.example.com
