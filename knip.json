{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "apps/store": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/admin": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/shared": {
      "entry": [
        "src/types/dto/*.ts",
        "src/types/view/*.ts",
        "src/constants/*.ts",
        "src/utils/*.ts",
        "src/mappers/*.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "packages/supabase": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": ["@seed-design/react"],
  "ignoreBinaries": ["supabase", "only-allow"]
}
